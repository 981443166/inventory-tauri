{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "极简进销存",
  "version": "0.1.0",
  "identifier": "com.inventory.pro",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "极简进销存系统",
        "width": 900,
        "height": 600,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true,
        "minWidth": 700,
        "minHeight": 500
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
